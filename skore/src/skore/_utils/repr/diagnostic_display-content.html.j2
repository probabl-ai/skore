{% set report_tabs = [
    {"label": issue_label, "help_variant": "text", "help_text": "Modeling problems flagged by applicable checks."},
    {"label": tip_label, "help_variant": "text", "help_text": "Cautions to keep in mind when interpreting the results."},
    {"label": passed_label, "help_variant": "text", "help_text": "Checks that ran on your report without flagging anything."},
] %}
<div class="container">
    <header class="title">{{ header | e }}</header>
    <div class="report-tabset">
        {% include "_report_tabset_chrome.html.j2" %}
        <div class="report-tab-panels">
            <div class="report-tab-panel">
                <div class="report-section report-diagnostic">{{ issue_html | safe }}</div>
            </div>
            <div class="report-tab-panel">
                <div class="report-section report-diagnostic">{{ tip_html | safe }}</div>
            </div>
            <div class="report-tab-panel">
                <div class="report-section report-diagnostic">{{ passed_html | safe }}</div>
            </div>
        </div>
    </div>
    <p class="report-hint-note" role="note">
        Mute a check by passing its code to <code>ignore</code>,
        e.g. <code>.diagnose(ignore=['SKD001'])</code>.
    </p>
</div>
