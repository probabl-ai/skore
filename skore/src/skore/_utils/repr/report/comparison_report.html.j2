<div id="{{ container_id }}-wrapper">
    <template id="{{ container_id }}-template">
        <style>
{% include "common/css/theme.css" %}
{% include "common/css/help.css" %}
{% include "common/css/report.css" %}
        </style>
        {% include "report/comparison_report-content.html.j2" %}
    </template>

    <div id="{{ container_id }}">
        {% for row in comparison_reports %}
        <div
            class="skore-cmp-estimator-slot"
            data-comparison-index="{{ loop.index0 }}"
            {% if loop.index0 == 0 %} slot="estimator-display"{% endif %}
        >{{ row.estimator_display | safe }}</div>
        <div
            class="skore-cmp-table-slot"
            data-comparison-index="{{ loop.index0 }}"
            {% if loop.index0 == 0 %} slot="table-report"{% endif %}
        >{{ row.table_report | safe }}</div>
        <div
            class="skore-cmp-checks-summary-slot"
            data-comparison-index="{{ loop.index0 }}"
            {% if loop.index0 == 0 %} slot="checks-summary"{% endif %}
        >{{ row.checks_summary | safe }}</div>
        {% endfor %}
    </div>

    <script>
{% include "common/js/report_theme.js" %}
{% include "report/js/comparison_report.js" %}
    </script>
</div>

<script>
skoreInitComparisonReport("{{ container_id }}");
</script>
