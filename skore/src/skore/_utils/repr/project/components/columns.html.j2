<div class="skore-summary-columns">
    <button type="button" class="skore-summary-columns-toggle" aria-haspopup="true" aria-expanded="false" aria-label="Show columns" title="Show columns">{% include "project/icons/more-v.svg" %}</button>
    <div class="skore-summary-columns-panel" hidden>
        {% for column in columns %}
        <label class="skore-summary-columns-option">
            <input type="checkbox" class="skore-summary-column-toggle" data-column-index="{{ loop.index }}" data-column-key="{{ column.key | e }}" checked>
            {{ column.label | e }}
        </label>
        {% endfor %}
    </div>
</div>
