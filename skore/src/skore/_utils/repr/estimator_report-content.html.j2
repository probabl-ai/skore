<div class="container">
    <header class="title">EstimatorReport</header>
    <details open class="report-disclosure">
        <summary>
            <span
                class="method-tooltip report-disclosure-title"
                tabindex="0"
            >Results<span class="tooltip-text">Investigate more with <a
                    href="{{ metrics_accessor_doc_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="report-tooltip-accessor-link"
                >{{ report_class_name }}.metrics</a></span></span>
        </summary>
        <div class="report-section report-metrics">{{ metrics_summary | safe }}</div>
    </details>
    <details class="report-disclosure">
        <summary>
            <span
                class="method-tooltip report-disclosure-title"
                tabindex="0"
            >Estimator<span class="tooltip-text">Investigate more with <a
                    href="{{ inspection_accessor_doc_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="report-tooltip-accessor-link"
                >{{ report_class_name }}.inspection</a></span></span>
        </summary>
        <div class="report-section report-estimator"><slot name="estimator-display"></slot></div>
    </details>
    <details class="report-disclosure">
        <summary>
            <span
                class="method-tooltip report-disclosure-title"
                tabindex="0"
            >Data<span class="tooltip-text">Investigate more with <a
                    href="{{ data_accessor_doc_url }}"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="report-tooltip-accessor-link"
                >{{ report_class_name }}.data</a></span></span>
        </summary>
        <div class="report-section report-data"><slot name="table-report"></slot></div>
    </details>
    <p class="report-hint-note" role="note">
        Use
        <a
            href="{{ help_doc_url }}"
            target="_blank"
            rel="noopener noreferrer"
            class="report-hint-note-link"
        >.help()</a>
        for information on available functionality.
    </p>
</div>
